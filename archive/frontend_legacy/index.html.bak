        <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
          <button class="btn btn-sm" onclick="showBeastPanel()">🦊 灵兽</button>
          <button class="btn btn-sm" onclick="showSectPanel()">🏛️ 宗门</button>
