            <div style="font-size:16px;font-weight:bold;color:#4ecdc4">灵兽系统</div>
            <div style="font-size:12px;color:#888" id="beastQuickInfo">点击查看灵兽</div>
          </div>
          <div style="font-size:20px">▶</div>
        </div>
      </div>

      <!-- 新系统快捷入口 -->
