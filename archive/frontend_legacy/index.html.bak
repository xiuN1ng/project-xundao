          <div class="stat-item"><div class="stat-value" id="totalSpirit">0</div><div class="stat-label">累计灵气</div></div>
          <div class="stat-item"><div class="stat-value" id="combatWins">0</div><div class="stat-label">战斗胜利</div></div>
        </div>
      </div>

      <!-- 灵兽快捷入口 -->
