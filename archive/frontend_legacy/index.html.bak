          <button class="btn btn-sm" onclick="showMasterPanel()">🎓 师徒</button>
          <button class="btn btn-sm" onclick="showPartnerPanel()">💕 仙侣</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#fbbf24,#f59e0b)" onclick="showVipPanel()">💎 VIP会员</button>
          <button class="btn btn-sm" onclick="showRealmDungeonPanel()">🏰 境界副本</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#8b5cf6,#6d28d9)" onclick="showResourceDungeonPanel()">📦 资源副本</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#f59e0b,#d97706)" onclick="showDailyBonusPanel()">🎁 每日奖励</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#ec4899,#be185d)" onclick="showAchievementPanel()">🏅 成就</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#10b981,#059669)" onclick="showShopPanel()">🛒 商城</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#ffd700,#ff8c00)" onclick="showRankingPanel()">🏆 排行榜</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#ef4444,#dc2626)" onclick="showSectWarPanel()">⚔️ 宗门战</button>
          <button class="btn btn-sm" style="background:linear-gradient(135deg,#667eea,#764ba2);grid-column:span 2" onclick="showMailPanel()">📧 邮件</button>
        </div>
      </div>
    </div>

    <!-- 右侧 -->
